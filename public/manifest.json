{
  "manifest_version": 3,
  "name": "PrinChat - WhatsApp Automation",
  "version": "1.0.0",
  "description": "Send messages and audio to WhatsApp Web with one click. Create scripts, triggers, and automate your communication.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": [
        "*://web.whatsapp.com/*"
      ],
      "js": [
        "content/whatsapp-injector.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "externally_connectable": {
    "matches": [
      "*://web.whatsapp.com/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "logo.png",
        "content/whatsapp-page-script.js",
        "content/whatsapp-store-accessor.js",
        "content/script-loader.js",
        "content/whatsapp-ui-overlay.js",
        "content/whatsapp-ui-overlay.css",
        "content/whatsapp-fab.js",
        "content/whatsapp-fab.css",
        "src/popup/index.html",
        "src/fab-popup/index.html",
        "fab-popup.js",
        "popup.js",
        "chunks/*",
        "wppconnect-wa.js",
        "fab-icon.png"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}